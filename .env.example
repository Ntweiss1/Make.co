# Frontend
VITE_API_URL=http://localhost:3001/api
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# Backend - Database
DATABASE_URL=postgresql://user:password@localhost:5432/makeco

# Backend - JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Backend - OpenAI (ChatGPT)
OPENAI_API_KEY=sk-your_openai_api_key

# Backend - Image Generation (Stability AI)
STABILITY_API_KEY=your_stability_api_key
STABILITY_API_HOST=api.stability.ai

# Backend - Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Backend - Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Backend - SendGrid Email
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@make.co

# Backend - AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=makeco-uploads
AWS_REGION=us-east-1

# Backend - General
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Backend - Optional: Sendgrid/Email
EMAIL_FROM=support@make.co
EMAIL_SUPPORT=support@make.co
